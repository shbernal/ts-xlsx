{
  "name": "@shbernal/ts-xlsx",
  "version": "0.0.0-dev",
  "description": "A TypeScript-first library for reading and writing xlsx (OOXML) spreadsheets.",
  "private": true,
  "license": "MIT",
  "author": "shbernal",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/shbernal/ts-xlsx.git"
  },
  "homepage": "https://github.com/shbernal/ts-xlsx#readme",
  "bugs": {
    "url": "https://github.com/shbernal/ts-xlsx/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:src": "node --test \"src/**/*.test.ts\"",
    "corpus": "node test/corpus/run.mjs",
    "test": "npm run typecheck && npm run test:src && npm run corpus",
    "validate:ooxml": "dotnet run --project tools/ooxml-validator/OoxmlValidator.csproj --configuration Release --",
    "test:ooxml": "dotnet restore tools/ooxml-validator/OoxmlValidator.csproj --locked-mode && node test/ooxml-validation/run.mjs",
    "harvest": "node scripts/harvest/fetch-issue.mjs",
    "harvest:list": "node scripts/harvest/list-backlog.mjs",
    "harvest:all": "node scripts/harvest/harvest-all.mjs",
    "harvest:status": "node scripts/harvest/status.mjs"
  },
  "keywords": [
    "xlsx",
    "ooxml",
    "excel",
    "spreadsheet",
    "csv",
    "typescript",
    "workbook",
    "streaming"
  ],
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "jszip": "^3.10.1",
    "typescript": "^5.9.3"
  }
}
