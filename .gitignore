# Logs
*.log

# Build output
dist/

# Coverage
coverage/

# Dependencies
node_modules/

# A stray npm lockfile would shadow pnpm-lock.yaml; keep it out of history.
package-lock.json

# Editors
.idea/
.vscode/

# OS
.DS_Store

# Generated xlsx during tests…
*.xlsx
# …but durable corpus fixtures are the exception: they are the regression corpus's
# sample inputs and MUST be tracked (see test/corpus/README.md).
!test/corpus/fixtures/**

# Harvested attachment binaries are regenerable scratch (pnpm harvest:all).
# Durable fixtures are promoted into test/corpus/fixtures/. Keep binaries out of history.
docs/knowledge/backlog/attachments/

# Development-only .NET OOXML validator build output
tools/ooxml-validator/bin/
tools/ooxml-validator/obj/
